{
  "name": "OpenCode Agent Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "agent-task",
        "responseMode": "lastNode"
      },
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:4096/session",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "title", "value": "={{ 'n8n-' + $json.agent }}" }
          ]
        }
      },
      "name": "Create Session",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'http://localhost:4096/session/' + $json.data.id + '/message' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ agent: $('Webhook Trigger').item.json.agent, parts: [{ type: 'text', text: $('Webhook Trigger').item.json.prompt }] }) }}"
      },
      "name": "Send to Agent",
      "type": "n8n-nodes-base.httpRequest",
      "position": [750, 300]
    },
    {
      "parameters": {},
      "name": "Return Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1000, 300]
    }
  ],
  "connections": {
    "Webhook Trigger": { "main": [[{ "node": "Create Session", "type": "main", "index": 0 }]] },
    "Create Session": { "main": [[{ "node": "Send to Agent", "type": "main", "index": 0 }]] },
    "Send to Agent": { "main": [[{ "node": "Return Response", "type": "main", "index": 0 }]] }
  }
}
