{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://10.0.0.224:11434/v1"
      },
      "models": {
        "qwen2.5-coder:14b": { "name": "Qwen 2.5 Coder 14B" },
        "qwen3.5:9b": { "name": "Qwen 3.5 9B" },
        "qwen3:8b": { "name": "Qwen 3 8B" },
        "qwen3-vl:8b": { "name": "Qwen 3 VL 8B" },
        "qwen3-vl:4b": { "name": "Qwen 3 VL 4B" },
        "qwen-8b-32k:latest": { "name": "Qwen 8B 32K" },
        "llama3.1:8b": { "name": "Llama 3.1 8B" }
      }
    }
  },
  "agent": {
    "api-agent": {
      "description": "Interacts with external applications via their OpenAPI specs",
      "mode": "subagent",
      "model": "ollama/qwen2.5-coder:14b",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "nokia-netops-agent": {
      "description": "Generates Nokia SR Linux and SR OS configs and Containerlab topologies from a ChromaDB knowledge base",
      "mode": "subagent",
      "model": "ollama/qwen2.5-coder:14b",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "dtaas-deploy-agent": {
      "description": "Deploys Containerlab topologies to the DTaaS platform via its REST API",
      "mode": "subagent",
      "model": "ollama/qwen2.5-coder:14b",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "read": true
      }
    },
    "test-writer-agent": {
      "description": "Generates and runs network test cases for deployed labs via the Test Runner API",
      "mode": "subagent",
      "model": "ollama/qwen2.5-coder:14b",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "read": true
      }
    }
  }
}
